    "/tiles/{layer_id}/{z}/{x}/{y}/labels.pbf": {
      "get": {
        "tags": [
          "MVT"
        ],
        "summary": "Get Label Tile",
        "description": "Get a label tile for a specific layer using point-on-surface geometries.\n\nReturns one point per node (the pole of inaccessibility), so each polygon\ngets exactly one label placement regardless of how many tiles it spans.\nIncludes all configured data field values as tile properties so the frontend\ncan dynamically switch the displayed label field.",
        "operationId": "get_label_tile_tiles__layer_id___z___x___y__labels_pbf_get",
        "parameters": [
          {
            "name": "layer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Layer Id"
            }
          },
          {
            "name": "z",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Z"
            }
          },
          {
            "name": "x",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "X"
            }
          },
          {
            "name": "y",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Y"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
