    "/tiles/{layer_id}/{z}/{x}/{y}.pbf": {
      "get": {
        "tags": [
          "MVT"
        ],
        "summary": "Get Tile",
        "description": "Get a vector tile for a specific layer at the given tile coordinates.\n\nArgs:\n    layer_id: The layer ID to render nodes from\n    z: Zoom level\n    x: Tile X coordinate\n    y: Tile Y coordinate\n    db: Database session\n\nReturns:\n    Mapbox Vector Tile (MVT) in protobuf format",
        "operationId": "get_tile_tiles__layer_id___z___x___y__pbf_get",
        "parameters": [
          {
            "name": "layer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Layer Id"
            }
          },
          {
            "name": "z",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Z"
            }
          },
          {
            "name": "x",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "X"
            }
          },
          {
            "name": "y",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Y"
            }
          }
        ],
        "responses": {
